# Root-owned VM environment file used by systemd and docker compose.
# Create the real file at /etc/capstone/pipeline.env with:
#   sudo install -d -m 0750 /etc/capstone
#   sudo cp ops/vm/pipeline.env.example /etc/capstone/pipeline.env
#   sudo chmod 600 /etc/capstone/pipeline.env
# Then keep non-secret settings here and refresh approved secret values from
# Secret Manager with:
#   ./scripts/render_pipeline_env_from_secret_manager.sh \
#     --output-file /etc/capstone/pipeline.env \
#     --base-env-file /etc/capstone/pipeline.env

CAPSTONE_CONTAINER_ENV_FILE=/etc/capstone/pipeline.env

GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GCS_BUCKET=your-capstone-bucket
GCS_PREFIX=
GCP_BIGQUERY_RAW_DATASET=raw
GCP_BIGQUERY_ANALYTICS_DATASET=analytics
DBT_BIGQUERY_DATASET=analytics

FRED_API_KEY=
COMTRADE_API_KEY_DATA=
COMTRADE_API_KEY_DATA_A=
COMTRADE_API_KEY_DATA_B=

# VM runs stay keyless. Leave GOOGLE_APPLICATION_CREDENTIALS blank so the attached
# Compute Engine service account is discovered through the metadata server.
GOOGLE_AUTH_MODE=vm_metadata
GOOGLE_APPLICATION_CREDENTIALS=

POSTGRES_USER=capstone
POSTGRES_PASSWORD=capstone
POSTGRES_DB=capstone
POSTGRES_SCHEMA=ops

BATCH_PLAN_PATH=ops/batch_plan.json
EXECUTION_PROFILE=all_vm
EXECUTION_RUNTIME=vm
EXECUTION_PROFILE_PATH=ops/execution_profiles.json
OPS_POSTGRES_ENABLED=true
ENABLE_BIGQUERY_OPS_MIRROR=true
OPS_STRICT_BIGQUERY_MIRROR=false

# Optional Bruin-on-GCP VM cleanup:
# Disable AWS EC2 metadata probing noise inside Bruin/SDK dependency paths.
AWS_EC2_METADATA_DISABLED=true
# Optional: disable Bruin telemetry on the VM.
TELEMETRY_OPTOUT=true
