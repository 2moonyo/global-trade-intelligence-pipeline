{
  "project_id": "your-gcp-project-id",
  "gcp_location": "us-central1",
  "gcp_region": "us-central1",
  "gcp_zone": "us-central1-a",
  "gcs_bucket_name": "your-capstone-bucket",
  "gcs_prefix": "",
  "raw_dataset_id": "raw",
  "analytics_dataset_id": "analytics",
  "create_compute_vm": true,
  "vm_name": "free-tier-vm",
  "vm_machine_type": "e2-micro",
  "vm_boot_image": "debian-cloud/debian-11",
  "vm_boot_disk_size_gb": 10,
  "vm_boot_disk_type": "pd-standard",
  "vm_data_disk_name": "secondary-data-disk",
  "vm_data_disk_device_name": "data-disk",
  "vm_data_disk_size_gb": 20,
  "vm_data_disk_type": "pd-standard",
  "vm_data_mount_point": "/mnt/disks/capstone-data",
  "enable_vm_instance_schedule": true,
  "vm_schedule_name": "capstone-vm-schedule",
  "vm_schedule_timezone": "UTC",
  "vm_start_schedule": "45 5 * * *",
  "vm_stop_schedule": "45 10 * * *",
  "vm_service_account_email": null,
  "allow_force_destroy": false,
  "project_job_user_members": [
    "user:your.name@example.com"
  ],
  "storage_object_admin_members": [
    "user:your.name@example.com"
  ],
  "raw_dataset_editor_members": [
    "user:your.name@example.com"
  ],
  "analytics_dataset_editor_members": [
    "user:your.name@example.com"
  ],
  "analytics_dataset_viewer_members": [],
  "labels": {
    "env": "dev"
  }
}
