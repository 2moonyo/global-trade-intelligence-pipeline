GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GCS_BUCKET=your-capstone-bucket
GCS_PREFIX=
GCP_BIGQUERY_RAW_DATASET=raw
GCP_BIGQUERY_ANALYTICS_DATASET=analytics
DBT_BIGQUERY_DATASET=analytics
FRED_API_KEY=
COMTRADE_API_KEY_DATA=
COMTRADE_API_KEY_DATA_A=
COMTRADE_API_KEY_DATA_B=
# Docker Compose uses this path to inject runtime env vars into the containers.
# Keep ../.env for local Docker. On the VM, set /etc/capstone/pipeline.env.
CAPSTONE_CONTAINER_ENV_FILE=../.env
# Auth mode:
# auto = prefer a mounted ADC JSON if present, otherwise fall back to VM metadata auth
# local_adc = require a mounted ADC JSON for local Docker runs
# vm_metadata = ignore key files and use the attached GCP VM service account
GOOGLE_AUTH_MODE=auto
# For local Docker with a mounted ADC JSON, use /var/secrets/google/credentials.json.
# Leave blank when GOOGLE_AUTH_MODE=vm_metadata.
GOOGLE_APPLICATION_CREDENTIALS=
POSTGRES_USER=capstone
POSTGRES_PASSWORD=capstone
POSTGRES_DB=capstone
POSTGRES_SCHEMA=ops
BATCH_PLAN_PATH=ops/batch_plan.json
EXECUTION_PROFILE=all_vm
EXECUTION_RUNTIME=vm
EXECUTION_PROFILE_PATH=ops/execution_profiles.json
OPS_POSTGRES_ENABLED=true
ENABLE_BIGQUERY_OPS_MIRROR=true
OPS_STRICT_BIGQUERY_MIRROR=false
