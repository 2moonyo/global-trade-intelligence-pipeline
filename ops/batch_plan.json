    {
      "batch_id": "comtrade_bootstrap_phase_1",
      "dataset_name": "comtrade",
      "description": "Bootstrap the recent core Comtrade history for the prioritized reporter and commodity cohort from January 2020 through December 2025.",
      "schedule_lane": "bootstrap_phase_1",
      "phase": "bootstrap_1",
      "run_order": 10,
      "max_attempts": 3,
      "retry_backoff_seconds": 300,
      "planned_partition_count": 72,
      "planned_reporter_count": 16,
      "planned_cmd_code_count": 6,
      "planned_window_start": "2020-01",
      "planned_window_end": "2025-12",
      "batch_metadata": {
        "reporters": "97,100,156,251,528,642,724,842,643,699,710,818,792,360,076,591",
        "commodities": "1001,1005,1006,1201,2709,2710",
        "flows": "M,X"
      },
      "steps": [
        {
          "task_name": "extract",
          "command": [
            "python",
            "ingest/comtrade/comtrade_cli_annual_monthly_gap_chunked_by_reporter.py",
            "run-monthly-history",
            "--years",
            "2020,2021,2022,2023,2024,2025",
            "--reporters",
            "97,100,156,251,528,642,724,842,643,699,710,818,792,360,076,591",
            "--commodities",
            "1001,1005,1006,1201,2709,2710",
            "--flows",
            "M,X"
          ],
          "log_path": "logs/comtrade/comtrade_history_batch_phase_1.log"
        },
        {
          "task_name": "silver",
          "command": [
            "python",
            "ingest/comtrade/comtrade_silver.py",
            "--since-period",
            "202001",
            "--until-period",
            "202512",
            "--cmd-codes",
            "1001,1005,1006,1201,2709,2710",
            "--flow-codes",
            "M,X"
          ],
          "manifest_path": "logs/comtrade/comtrade_silver_manifest.jsonl"
        },
        {
          "task_name": "routing",
          "command": [
            "python",
            "-m",
            "ingest.comtrade.routing"
          ],
          "log_path": "logs/comtrade/comtrade_routing_phase_1.log"
        },
        {
          "task_name": "publish_gcs",
          "command": [
            "python",
            "warehouse/publish_comtrade_to_gcs.py",
            "--since-year-month",
            "2020-01",
            "--until-year-month",
            "2025-12"
          ],
          "manifest_path": "logs/comtrade/publish_comtrade_to_gcs_manifest.jsonl"
        },
        {
          "task_name": "load_bigquery",
          "command": [
            "python",
            "warehouse/load_comtrade_to_bigquery.py",
            "--since-year-month",
            "2020-01",
            "--until-year-month",
            "2025-12"
          ],
          "manifest_path": "logs/comtrade/load_comtrade_to_bigquery_manifest.jsonl"
        },
        {
          "task_name": "dbt_build",
          "command": [
            "scripts/run_dbt.sh",
            "build"
          ],
          "log_path": "logs/comtrade/dbt_build_phase_1.log"
        }
      ]
    },
